# ─────────────────────────────────────────────────────────────────────────────
# VoteWatch — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for data pipeline ────────────────────────────────────────────────

# Congress.gov API Key (FREE)
# Get yours in 2 minutes: https://api.congress.gov/sign-up/
# Used for: voting records, member data, bill information
CONGRESS_API_KEY=your_congress_api_key_here

# FEC Campaign Finance API Key (FREE)
# Get yours at: https://api.data.gov/signup/
# Used for: lobby donations, PAC contributions, campaign finance
FEC_API_KEY=your_fec_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# CourtListener API Token (FREE, but token = higher rate limits)
# Register at: https://www.courtlistener.com/sign-in/
# Used for: federal lawsuit data
# Without this token: 5,000 req/day (usually enough)
COURTLISTENER_TOKEN=

# OpenSecrets API Key (FREE for researchers — see README for how to apply)
# Apply at: https://www.opensecrets.org/open-data/api
# Used for: processed lobby industry data (much better than raw FEC)
# The pipeline works WITHOUT this — but data quality improves significantly with it
OPENSECRETS_API_KEY=

# ── Deployment ────────────────────────────────────────────────────────────────

# Your site URL (used for SEO canonical URLs)
# During development: http://localhost:3000
# After deployment: https://votewatch.pages.dev (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
