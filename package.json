{
  "name": "watchgov",
  "version": "1.0.0",
  "private": true,
  "description": "U.S. Political Transparency Tracker — lobby money, stock trades, lawsuits, voting records",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pipeline": "npx tsx scripts/pipeline.ts",
    "pipeline:test": "npx tsx scripts/pipeline.ts --limit=5",
    "pipeline:senate": "npx tsx scripts/pipeline.ts --chamber=Senate",
    "pipeline:house": "npx tsx scripts/pipeline.ts --chamber=House"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
